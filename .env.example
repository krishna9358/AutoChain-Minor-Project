# ╔══════════════════════════════════════════════════════════════════════╗
# ║  AutoChain AI — Root Environment Variables                          ║
# ║  Copy this file to .env and fill in your values.                    ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:autochain_dev@localhost:5432/autochain

# ─── Authentication ──────────────────────────────────────────────────
JWT_SECRET=autochain-dev-secret-key-change-in-production

# ─── Encryption (AES-256, must be exactly 32 characters) ─────────────
ENCRYPTION_KEY=autochain-dev-encryption-key-32ch

# ─── AI / LLM Configuration ─────────────────────────────────────────
# Groq — primary provider (free tier: https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — fallback provider (https://openrouter.ai)
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Kafka ───────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9094

# ─── Service Ports ───────────────────────────────────────────────────
# Backend:   3001
# Hooks:     3002
# Frontend:  3000
