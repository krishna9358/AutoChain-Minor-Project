# ╔══════════════════════════════════════════════════════════════════════╗
# ║  AutoChain AI — Root Environment Variables                          ║
# ║  Copy this file to .env and fill in your values.                    ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:autochain_dev@localhost:5432/autochain

# ─── Authentication ──────────────────────────────────────────────────
JWT_SECRET=autochain-dev-secret-key-change-in-production

# ─── Encryption (AES-256, must be exactly 32 characters) ─────────────
ENCRYPTION_KEY=autochain-dev-encryption-key-32ch

# ─── AI Provider Configuration ─────────────────────────────────────
# Works with any OpenAI-compatible API (Groq, OpenRouter, OpenAI, Ollama, etc.)
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7
ENABLE_AI_GENERATION=true

# Legacy (still supported for backward compatibility):
# GROQ_API_KEY=xxx
# OPENROUTER_API_KEY=xxx

# ─── Kafka ───────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9094

# ─── Service Ports ───────────────────────────────────────────────────
# Backend:   3001
# Hooks:     3002
# Frontend:  3000
