FROM node:20-alpine
WORKDIR /app
COPY package.json yarn.lock* package-lock.json* ./
RUN if [ -f yarn.lock ]; then yarn install; \
    elif [ -f package-lock.json ]; then npm ci; \
    else npm install; fi
COPY . .
EXPOSE 3000
# Re-run install at startup to sync node_modules volume with package.json
CMD sh -c "yarn install --frozen-lockfile 2>/dev/null || npm install && npm run dev"
