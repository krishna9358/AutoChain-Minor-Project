# ─── Database Configuration ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:agentflow_dev@localhost:5432/agentflow

# ─── Server Configuration ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
HOST=0.0.0.0

# ─── Authentication ─────────────────────────────────────────────────
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d

# ─── Kafka Configuration ───────────────────────────────────────────
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=agentflow-backend
KAFKA_GROUP_ID=backend-group

# ─── Outbox Pattern Configuration ──────────────────────────────────
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL=5000
OUTBOX_BATCH_SIZE=100

# ─── Worker Configuration ───────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_RETRY_ATTEMPTS=3
WORKER_RETRY_DELAY=1000

# ─── AI Configuration ─────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# ─── Webhook Configuration ─────────────────────────────────────────
WEBHOOK_SECRET=replace-me
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3

# ─── CORS Configuration ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization

# ─── Logging Configuration ────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── File Upload Configuration ─────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/json,text/plain,application/pdf

# ─── Metrics & Monitoring ─────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ─── Feature Flags ─────────────────────────────────────────────────
ENABLE_AI_GENERATION=true
ENABLE_WORKFLOW_VERSIONING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_APPROVALS=true
