# ─── Database Configuration ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:autochain_dev@localhost:5432/autochain

# ─── Server Configuration ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
HOST=0.0.0.0

# ─── Authentication ─────────────────────────────────────────────────
JWT_SECRET=autochain-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Kafka Configuration ───────────────────────────────────────────
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=autochain-backend
KAFKA_GROUP_ID=backend-group

# ─── Outbox Pattern Configuration ──────────────────────────────────
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL=5000
OUTBOX_BATCH_SIZE=100

# ─── Worker Configuration ───────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_RETRY_ATTEMPTS=3
WORKER_RETRY_DELAY=1000

# ─── AI Provider Configuration ────────────────────────────────────
# Works with any OpenAI-compatible API (Groq, OpenRouter, OpenAI, Ollama, etc.)
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Legacy (still supported for backward compatibility):
# GROQ_API_KEY=xxx
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=xxx
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Webhook Configuration ─────────────────────────────────────────
WEBHOOK_SECRET=replace-me
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3

# ─── CORS Configuration ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization

# ─── Logging Configuration ────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── File Upload Configuration ─────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/json,text/plain,application/pdf

# ─── Metrics & Monitoring ─────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ─── Feature Flags ─────────────────────────────────────────────────
ENABLE_AI_GENERATION=true
ENABLE_WORKFLOW_VERSIONING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_APPROVALS=true
